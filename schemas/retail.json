    {
      "name": "same_store_name_diff_address",
      "entity_type": "store",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"store_name\"], \"attr_fields\": [\"address_line1\", \"city\", \"state_code\", \"store_type\"]}"
    },
    {
      "name": "same_sku_diff_product",
      "entity_type": "product",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"sku\"], \"attr_fields\": [\"product_name\", \"department\", \"unit_price\", \"supplier\"]}"
    },
    {
      "name": "same_loyalty_card_diff_name",
      "entity_type": "customer",
