    },
    {
      "name": "same_email_diff_customer",
      "entity_type": "customer",
      "config_json": "{\"pattern\": \"same_email\", \"email_col\": \"email\", \"attr_fields\": [\"first_name\", \"last_name\", \"loyalty_card\", \"phone\"]}"
    },
    {
      "name": "same_transaction_number_diff_store",
      "entity_type": "sale",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"transaction_number\"], \"attr_fields\": [\"store_id\", \"sale_date\", \"total_amount\"]}"
    },
    {
      "name": "same_customer_same_date",
