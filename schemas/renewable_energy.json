  "hn_types": [
    {
      "name": "same_asset_name_diff_source",
      "entity_type": "energy_asset",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"asset_name\"], \"attr_fields\": [\"energy_source\", \"capacity_mw\", \"city\", \"commission_date\"]}"
    },
    {
      "name": "same_source_same_location",
      "entity_type": "energy_asset",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"energy_source\", \"city\"], \"attr_fields\": [\"asset_name\", \"capacity_mw\", \"commission_date\"]}"
    },
    {
      "name": "same_reading_date_same_asset",
      "entity_type": "energy_generation_record",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"reading_date\", \"asset_id\"], \"attr_fields\": [\"output_mwh\", \"efficiency\"]}"
    },
    {
      "name": "same_technician_same_date",
      "entity_type": "maintenance",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"technician\", \"scheduled_date\"], \"attr_fields\": [\"maintenance_type\", \"completed_date\", \"cost\"]}"
    },
    {
      "name": "same_certificate_number_diff_asset",
      "entity_type": "certificate",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"certificate_number\"], \"attr_fields\": [\"cert_type\", \"issuance_date\", \"mwh_certified\", \"buyer\"]}"
    },
    {
      "name": "same_buyer_same_date",
      "entity_type": "certificate",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"buyer\", \"issuance_date\"], \"attr_fields\": [\"certificate_number\", \"cert_type\", \"mwh_certified\"]}"
    }
  ]
