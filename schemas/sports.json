  "hn_types": [
    {
      "name": "same_name_diff_dob",
      "entity_type": "athlete",
      "config_json": "{\"pattern\": \"same_name_different_everything\", \"first_name_col\": \"first_name\", \"last_name_col\": \"last_name\", \"attr_fields\": [\"date_of_birth\", \"nationality\", \"height_cm\", \"weight_kg\"]}"
    },
    {
      "name": "same_name_same_sport",
      "entity_type": "athlete",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"first_name\", \"last_name\", \"sport\"], \"attr_fields\": [\"date_of_birth\", \"nationality\", \"position\", \"height_cm\"]}"
    },
    {
      "name": "same_team_diff_league",
      "entity_type": "team",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"team_name\"], \"attr_fields\": [\"league\", \"country\", \"founded_year\", \"home_stadium\"]}"
    },
    {
      "name": "same_athlete_same_team_overlap",
      "entity_type": "contract",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"athlete_id\", \"team_id\"], \"attr_fields\": [\"start_date\", \"end_date\", \"salary\", \"contract_type\"]}"
    },
    {
      "name": "same_competition_same_season",
      "entity_type": "competition",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"competition_name\", \"season\"], \"attr_fields\": [\"sport\", \"category\"]}"
    },
    {
      "name": "same_home_away_same_date",
      "entity_type": "game",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"home_team_id\", \"away_team_id\", \"game_date\"], \"attr_fields\": [\"home_score\", \"away_score\", \"venue\", \"competition_id\"]}"
    },
    {
      "name": "same_game_same_athlete",
      "entity_type": "game_stat",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"game_id\", \"athlete_id\"], \"attr_fields\": [\"minutes_played\", \"points_scored\", \"assists\", \"rebounds\"]}"
    },
    {
      "name": "same_athlete_same_date",
      "entity_type": "transfer",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"athlete_id\", \"transfer_date\"], \"attr_fields\": [\"from_team_id\", \"to_team_id\", \"transfer_fee\", \"transfer_type\"]}"
    }
