      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"merchant_id\", \"amount\"], \"attr_fields\": [\"account_id\", \"transaction_type\", \"payment_method\", \"transaction_date\"]}"
    },
    {
      "name": "same_customer_diff_account",
