    {
      "name": "same_name_diff_ssn",
      "entity_type": "customer",
      "config_json": "{\"pattern\": \"same_name_different_everything\", \"first_name_col\": \"first_name\", \"last_name_col\": \"last_name\", \"attr_fields\": [\"email\", \"phone\", \"ssn\", \"birth_date\", \"city\"]}"
    },
    {
      "name": "same_ssn_diff_name",
      "entity_type": "customer",
      "config_json": "{\"pattern\": \"same_ssn\", \"ssn_col\": \"ssn\", \"attr_fields\": [\"first_name\", \"last_name\", \"email\", \"birth_date\", \"city\"]}"
    },
    {
      "name": "same_phone_diff_person",
      "entity_type": "customer",
      "config_json": "{\"pattern\": \"same_phone\", \"phone_col\": \"phone\", \"attr_fields\": [\"first_name\", \"last_name\", \"email\", \"birth_date\"]}"
    },
    {
      "name": "same_account_same_type_diff_amount",
      "entity_type": "payment_transaction",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"account_id\", \"transaction_type\"], \"attr_fields\": [\"amount\", \"merchant_id\", \"payment_method\", \"transaction_date\"]}"
    },
    {
      "name": "same_merchant_same_amount",
