  "hn_types": [
    {
      "name": "same_ssn_diff_holder",
      "entity_type": "policy_holder",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"ssn\"], \"attr_fields\": [\"first_name\", \"last_name\", \"date_of_birth\", \"email\"]}"
    },
    {
      "name": "same_address_diff_holder",
      "entity_type": "policy_holder",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"address_line1\", \"postal_code\"], \"attr_fields\": [\"first_name\", \"last_name\", \"phone\"]}"
    },
    {
      "name": "same_vin_diff_policy",
      "entity_type": "policy",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"vin\"], \"attr_fields\": [\"policy_type\", \"holder_id\", \"premium_amount\"]}"
    },
    {
      "name": "same_claim_details_diff_policy",
      "entity_type": "claim",
      "config_json": "{\"pattern\": \"same_field\", \"id_fields\": [\"claim_amount\", \"claim_type\"], \"attr_fields\": [\"policy_id\", \"status\", \"adjuster_id\"]}"
    },
    {
      "name": "similar_license_one_char",
      "entity_type": "agent",
      "config_json": "{\"pattern\": \"mix_identifier\", \"mix_field\": \"license_number\", \"attr_fields\": [\"agency_name\", \"agent_email\"]}"
    }
  ]
